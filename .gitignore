# Python bytecode and caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Editor / OS scratch
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Build / packaging artifacts
*.egg-info/
build/
dist/

# Local signing keys (SIGNATURE-RUNTIME-v0.1).
# HMAC-SHA256 keys are SECRETS. They MUST NOT be committed under any
# circumstance. The signature runtime refuses to operate if a key file
# is found outside this directory under the repo root.
.wiseorder_keys/

# Generated reports are intentionally NOT ignored:
#   reports/conformance-report.json
#   reports/conformance-summary.txt
#   reports/ci/**
#   reports/canonical/**
#   reports/repo_health/**
# These are evidence artifacts. They are regenerated by `make conformance`
# and committed so audit_status=CONFORMANT declarations have a referent.

# Per-run report noise — archived (WORK ORDER 011). Not load-bearing.
# Canonical evidence is kept under reports/<runtime>/<runtime>_v0.{1,2}.{json,md}
# and at the top of reports/.
reports/archive/

# Rust verifier build artifacts (WORK ORDER 012). Sources under rust_verifier/
# (Cargo.toml, src/, tests/) ARE tracked; the build cache is not.
rust_verifier/target/
rust_verifier/Cargo.lock
**/*.rs.bk

# Go verifier build artifacts (WORK ORDER 013). Sources under go_verifier/
# (go.mod, *.go) ARE tracked; the Go build cache and workspace lock are not.
go.work.sum
